APP_NAME=DS-OCR2-3090-Runner
APP_ENV=local
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dsocr
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
STORAGE_ROOT=./storage
OCR_BACKEND=stub
DEEPSEEK_OCR_PYTHON=python
DEEPSEEK_OCR_MODEL_DIR=./models/DeepSeek-OCR-2
DEEPSEEK_OCR_OUTPUT_ROOT=./storage/results/deepseek-ocr-2
DEEPSEEK_OCR_TIMEOUT_SECONDS=900
DEEPSEEK_OCR_BASE_SIZE=1024
DEEPSEEK_OCR_IMAGE_SIZE=768
DEEPSEEK_OCR_CROP_MODE=true
DEEPSEEK_OCR_ATTN_IMPLEMENTATION=eager
DEEPSEEK_OCR_DTYPE=bfloat16
QUEUE_VISIBILITY_TIMEOUT_SECONDS=900
WORKER_ID=local-worker
